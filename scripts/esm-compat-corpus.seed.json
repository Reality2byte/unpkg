{
  "name": "seed",
  "description": "Representative npm package scenarios for esm.sh compatibility checks.",
  "cases": [
    {
      "category": "package-root",
      "description": "React package root",
      "expect": "module",
      "features": ["package-root", "version"],
      "package": "react",
      "path": "/react@18.3.1"
    },
    {
      "category": "subpath",
      "description": "React DOM client subpath",
      "expect": "module",
      "features": ["subpath", "version"],
      "package": "react-dom",
      "path": "/react-dom@18.3.1/client"
    },
    {
      "category": "external",
      "description": "External all shorthand",
      "expect": "module",
      "features": ["external-all"],
      "package": "swr",
      "path": "/*swr@1.3.0"
    },
    {
      "category": "external",
      "description": "Explicit external dependency",
      "expect": "module",
      "features": ["external"],
      "package": "react-dom",
      "path": "/react-dom@18.3.1/client?external=react"
    },
    {
      "category": "dependency-control",
      "description": "Dependency override",
      "expect": "module",
      "features": ["deps"],
      "package": "react-dom",
      "path": "/react-dom@18.3.1/client?deps=react@18.2.0"
    },
    {
      "category": "dependency-control",
      "description": "Alias React to Preact compat",
      "expect": "module",
      "features": ["alias", "deps"],
      "package": "react-dom",
      "path": "/react-dom@18.3.1/client?alias=react:preact/compat&deps=preact@10.25.4"
    },
    {
      "category": "bundling",
      "description": "No-bundle mode",
      "expect": "module",
      "features": ["no-bundle"],
      "package": "preact",
      "path": "/preact@10.26.4/hooks?no-bundle"
    },
    {
      "category": "bundling",
      "description": "Bundle false mode",
      "expect": "module",
      "features": ["bundle-false"],
      "package": "preact",
      "path": "/preact@10.26.4/hooks?bundle=false"
    },
    {
      "category": "bundling",
      "description": "Explicit bundle mode",
      "expect": "module",
      "features": ["bundle"],
      "package": "preact",
      "path": "/preact@10.26.4/hooks?bundle"
    },
    {
      "category": "bundling",
      "description": "Standalone bundle mode",
      "expect": "module",
      "features": ["standalone"],
      "package": "preact",
      "path": "/preact@10.26.4/hooks?standalone"
    },
    {
      "category": "raw",
      "description": "Raw package file",
      "expect": "json",
      "features": ["raw"],
      "package": "react",
      "path": "/react@18.3.1/package.json?raw"
    },
    {
      "category": "diagnostic",
      "description": "Raw mode rejects transform flags",
      "expect": "diagnostic",
      "features": ["raw", "invalid-query"],
      "package": "react",
      "path": "/react@18.3.1?raw&target=es2022"
    },
    {
      "category": "build-options",
      "description": "Development build flag",
      "expect": "module",
      "features": ["dev"],
      "package": "react",
      "path": "/react@18.3.1?dev"
    },
    {
      "category": "build-options",
      "description": "Development env option",
      "expect": "module",
      "features": ["env"],
      "package": "react",
      "path": "/react@18.3.1?env=development"
    },
    {
      "category": "build-options",
      "description": "Browser target option",
      "expect": "module",
      "features": ["target"],
      "package": "react",
      "path": "/react@18.3.1?target=es2015"
    },
    {
      "category": "build-options",
      "description": "Custom conditions option",
      "expect": "module",
      "features": ["conditions"],
      "package": "preact",
      "path": "/preact@10.26.4?conditions=browser,development"
    },
    {
      "category": "build-options",
      "description": "Keep names option",
      "expect": "module",
      "features": ["keep-names"],
      "package": "preact",
      "path": "/preact@10.26.4?keep-names"
    },
    {
      "category": "build-options",
      "description": "Ignore annotations option",
      "expect": "module",
      "features": ["ignore-annotations"],
      "package": "preact",
      "path": "/preact@10.26.4?ignore-annotations"
    },
    {
      "category": "build-options",
      "description": "Minified output option",
      "expect": "module",
      "features": ["min"],
      "package": "preact",
      "path": "/preact@10.26.4?min"
    },
    {
      "category": "build-options",
      "description": "Inline source map option",
      "expect": "module",
      "features": ["sourcemap"],
      "package": "preact",
      "path": "/preact@10.26.4?sourcemap"
    },
    {
      "category": "types",
      "description": "No DTS header option",
      "expect": "module",
      "features": ["no-dts"],
      "package": "preact",
      "path": "/preact@10.26.4?no-dts"
    },
    {
      "category": "import-map",
      "description": "Import-map-friendly path query syntax",
      "expect": "module",
      "features": ["path-query", "dev"],
      "package": "react-dom",
      "path": "/react-dom@18.3.1&dev/client"
    },
    {
      "category": "metadata",
      "description": "Metadata",
      "expect": "json",
      "features": ["meta"],
      "package": "preact",
      "path": "/preact@10.26.4?meta"
    },
    {
      "category": "worker",
      "description": "Worker wrapper",
      "expect": "module",
      "features": ["worker"],
      "package": "preact",
      "path": "/preact@10.26.4?worker"
    },
    {
      "category": "inline-runner",
      "description": "Inline TSX runner helper",
      "expect": "module",
      "features": ["tsx"],
      "path": "/tsx"
    },
    {
      "category": "inline-runner",
      "description": "Inline run helper",
      "expect": "module",
      "features": ["run"],
      "path": "/run"
    },
    {
      "category": "runtime-target",
      "description": "Runtime-native target",
      "expect": "module",
      "features": ["target-node"],
      "package": "react",
      "path": "/react@18.3.1?target=node"
    },
    {
      "category": "diagnostic",
      "description": "Unsupported source diagnostic",
      "expect": "diagnostic",
      "features": ["unsupported-source"],
      "package": "preact",
      "path": "/preact@10.26.4/component.vue"
    },
    {
      "category": "css",
      "description": "CSS package root",
      "expect": "css",
      "features": ["css", "package-root"],
      "package": "normalize.css",
      "path": "/normalize.css@8.0.1"
    },
    {
      "category": "css",
      "description": "Direct CSS file",
      "expect": "css",
      "features": ["css", "subpath"],
      "package": "bootstrap",
      "path": "/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    },
    {
      "category": "css",
      "description": "Constructable stylesheet module",
      "expect": "module",
      "features": ["css", "css-module"],
      "package": "react-toastify",
      "path": "/react-toastify@11.0.5/dist/ReactToastify.css?module"
    },
    {
      "category": "css",
      "description": "Explicit CSS request without a stylesheet",
      "expect": "diagnostic",
      "features": ["css", "css-not-found"],
      "package": "react",
      "path": "/react@18.3.1?css"
    }
  ]
}
